<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ device-to-device transfer / cloud backup rules. Opt-out for privacy. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose applies the full theme in code. This resource theme only provides
         window attributes so the splash/startup frame matches before Compose attaches. -->
    <style name="Theme.CoreChat" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/background_default</item>
        <item name="android:navigationBarColor">@color/background_default</item>
        <item name="android:windowBackground">@color/background_default</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
